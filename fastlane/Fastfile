default_platform(:ios)

platform :ios do
  desc "FULLY AUTOMATIC TestFlight deployment"
  lane :deploy do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Load API key
    api_key = app_store_connect_api_key(
      key_id: "U5W7H8NLHM",
      issuer_id: "69a6de74-4a5e-47e3-e053-5b8c7c11a4d1",
      key_filepath: "fastlane/AuthKey_U5W7H8NLHM.p8",
      duration: 1200
    )
    
    # Get latest build number and increment
    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.nuri.mobile-ios"
    )
    next_build = current_build + 1
    
    puts "📱 Current TestFlight build: #{current_build}"
    puts "🚀 Building version: #{next_build}"
    
    # Ensure we have the latest provisioning profile
    sigh(
      app_identifier: "com.nuri.mobile-ios",
      api_key: api_key,
      readonly: true
    )
    
    # Build and upload
    gym(
      workspace: "Nuri.xcworkspace",
      scheme: "Nuri",
      configuration: "Release",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      export_method: "app-store",
      export_options: {
        method: "app-store-connect",
        teamID: "MH2SRQ3N27",
        signingStyle: "manual",
        signingCertificate: "Apple Distribution",
        provisioningProfiles: {
          "com.nuri.mobile-ios" => "com.nuri.mobile-ios AppStore"
        },
        uploadBitcode: false,
        uploadSymbols: false,
        compileBitcode: false
      },
      output_directory: "./builds",
      output_name: "Nuri-#{next_build}.ipa",
      destination: "generic/platform=iOS"
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.nuri.mobile-ios",
      ipa: "./builds/Nuri-#{next_build}.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Build #{next_build} - Automated deployment"
    )
    
    puts "✅ Successfully uploaded build #{next_build} to TestFlight!"
  end
  
  desc "Archive and export IPA with provisioning profile"
  lane :auto do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Build the archive
    sh("xcodebuild -workspace ../Nuri.xcworkspace \
        -scheme Nuri \
        -configuration Release \
        -destination 'generic/platform=iOS' \
        -archivePath ../fastlane/builds/Nuri.xcarchive \
        CURRENT_PROJECT_VERSION=11 \
        clean archive")
    
    # Export the IPA with the provisioning profile
    sh("xcodebuild -exportArchive \
        -archivePath ../fastlane/builds/Nuri.xcarchive \
        -exportPath ../fastlane/builds \
        -exportOptionsPlist ../fastlane/ExportOptions.plist")
    
    puts "✅ IPA exported to fastlane/builds/Nuri.ipa"
    
    # Now upload to TestFlight
    api_key = app_store_connect_api_key(
      key_id: "U5W7H8NLHM",
      issuer_id: "69a6de74-4a5e-47e3-e053-5b8c7c11a4d1",
      key_filepath: "fastlane/AuthKey_U5W7H8NLHM.p8"
    )
    
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.nuri.mobile-ios",
      ipa: "./builds/Nuri.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
    
    puts "✅ Successfully uploaded to TestFlight!"
  end
  
  desc "Build archive only (no export)"
  lane :archive do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Build the archive without exporting
    gym(
      workspace: "Nuri.xcworkspace",
      scheme: "Nuri",
      configuration: "Release",
      clean: true,
      output_directory: "./builds",
      skip_package_ipa: true,
      archive_path: "./builds/Nuri.xcarchive",
      destination: "generic/platform=iOS"
    )
    
    puts "Archive created at: ./builds/Nuri.xcarchive"
    puts "You can now open this archive in Xcode Organizer to manually distribute"
  end
end