default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Ensure we're on the right branch
    ensure_git_status_clean
    
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Get current build number from TestFlight
    build_number = latest_testflight_build_number + 1
    
    # Build the app with specific build number
    build_app(
      workspace: "Nuri.xcworkspace",
      scheme: "Nuri",
      export_method: "app-store",
      build_number: build_number.to_s,
      export_options: {
        provisioningProfiles: {
          "com.nuri.mobile-ios" => "match AppStore com.nuri.mobile-ios"
        }
      },
      output_directory: "./builds",
      output_name: "Nuri.ipa"
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: "6736962812"
    )
  end
  
  desc "Build for TestFlight without uploading"
  lane :build_only do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Build the app
    build_app(
      workspace: "Nuri.xcworkspace",
      scheme: "Nuri",
      export_method: "app-store",
      output_directory: "./builds",
      output_name: "Nuri-TestFlight.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "NSLWDP4W5G",
        provisioningProfiles: {
          "com.nuri.mobile-ios" => "com.nuri.mobile-ios AppStore"
        }
      }
    )
  end
  
  desc "Build archive only (no export)"
  lane :archive do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Build the archive without exporting
    gym(
      workspace: "Nuri.xcworkspace",
      scheme: "Nuri",
      configuration: "Release",
      clean: true,
      output_directory: "./builds",
      skip_package_ipa: true,
      archive_path: "./builds/Nuri.xcarchive"
    )
    
    puts "Archive created at: ./builds/Nuri.xcarchive"
    puts "You can now open this archive in Xcode Organizer to manually distribute"
  end
  
  desc "Build a simple archive without signing complications"
  lane :simple_archive do
    # Generate Xcode project with Tuist
    sh("cd .. && tuist generate")
    
    # Build using xcodebuild directly
    sh("cd .. && xcodebuild -workspace Nuri.xcworkspace -scheme Nuri -configuration Release -sdk iphoneos archive -archivePath fastlane/builds/Nuri.xcarchive")
    
    puts "Archive created at: ./builds/Nuri.xcarchive"
    puts "You can now:"
    puts "1. Open Xcode"
    puts "2. Go to Window → Organizer (⌘⇧2)"
    puts "3. Select your archive"
    puts "4. Click 'Distribute App'"
    puts "5. Choose 'App Store Connect' and follow the wizard"
  end
  
  desc "Upload existing IPA to TestFlight"
  lane :upload_ipa do
    upload_to_testflight(
      ipa: "./builds/Nuri-TestFlight.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
  
  desc "Build and upload to TestFlight"
  lane :build_and_upload do
    # Build the app
    build_only
    
    # Upload to TestFlight
    upload_ipa
  end
end